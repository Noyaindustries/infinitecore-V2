rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /**
     * Rôle du profil `users/{uid}` — chaîne vide si le document n’existe pas.
     * Ne jamais lire `.data` sur un get sans `exists`, sinon l’évaluation des règles échoue (permission-denied).
     */
    function userRole() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return u.exists ? u.data.role : '';
    }

    function isSuperAdmin() {
      return isAuthenticated() && userRole() == 'admin';
    }

    function isCommando() {
      return isAuthenticated() && userRole() == 'commando';
    }

    function isAdmin() {
      return isSuperAdmin() || isCommando();
    }

    function isStaff() {
      return isAuthenticated() &&
        userRole() in ['admin', 'commando', 'developer', 'partner'];
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.size() > 0 && dateStr.size() < 100;
    }

    function isValidEmail(email) {
      return email is string && email.size() > 0 && email.size() < 200;
    }

    // ===============================================================
    // Webhook validators (padde-ci.com / Netlify, no auth)
    // ===============================================================

    function isPaddeCiInboundTask(data) {
      return data.source == 'padde-ci' &&
        data.userId == 'system' &&
        data.columnId == 'nouveau' &&
        data.id is string && data.id.size() > 0 &&
        data.title is string && data.title.size() > 0 &&
        data.client is string && data.client.size() > 0 &&
        isValidDateString(data.createdAt);
    }

    function isPaddeCiInboundOrder(data) {
      return data.source == 'padde-ci' &&
        data.userId == 'system' &&
        data.status == 'Nouveau' &&
        data.id is string && data.id.size() > 0 &&
        data.clientName is string && data.clientName.size() > 0 &&
        data.serviceName is string && data.serviceName.size() > 0 &&
        isValidDateString(data.createdAt);
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Paramètres factures + compteur (commando / admin général)
    match /admin_config/{docId} {
      allow read, write: if isAdmin();
    }

    match /padde_audits/{auditId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() ||
                  (isAuthenticated() && resource.data.referredBy == request.auth.uid);

      allow create: if isAuthenticated() &&
                    (isOwner(userId) || isAdmin());

      allow update: if isAuthenticated() &&
                    (
                      (isOwner(userId) && request.resource.data.role == resource.data.role) ||
                      isAdmin()
                    );

      allow delete: if isSuperAdmin();
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin() || isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() &&
                    (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() &&
                    (
                      (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid) ||
                      isAdmin()
                    );
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || isPaddeCiInboundTask(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /documents/{documentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() &&
                    (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if (isAuthenticated() &&
                    (request.resource.data.userId == request.auth.uid || isAdmin())) ||
                    isPaddeCiInboundOrder(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /missions/{missionId} {
      allow read: if isAdmin() ||
                  (isAuthenticated() && (
                    resource.data.clientId == request.auth.uid ||
                    resource.data.assignedTo == request.auth.uid ||
                    resource.data.status == 'en_attente'
                  ));
      allow create: if isAdmin();
      allow update: if isAdmin() ||
                    (isAuthenticated() && resource.data.assignedTo == request.auth.uid &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() &&
                    (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    match /instances/{instanceId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /dossier_steps/{stepId} {
      // Client reads their own steps; admin reads all
      allow read: if isAdmin() ||
                  (isAuthenticated() && resource.data.clientId == request.auth.uid);
      // Only commando/admin can create steps
      allow create: if isAdmin();
      // Client can validate (update status + validatedAt only); admin can update anything
      allow update: if isAdmin() ||
                    (isAuthenticated() && resource.data.clientId == request.auth.uid &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'validatedAt']) &&
                     request.resource.data.status == 'valide');
      allow delete: if isAdmin();
    }

    match /leads/{leadId} {
      // Partner can read their own leads; admin/commando can read and update all
      allow read: if isAdmin() ||
                  (isAuthenticated() && resource.data.partnerId == request.auth.uid);
      // Partner can create leads (only for themselves)
      allow create: if isAuthenticated() &&
                    request.resource.data.partnerId == request.auth.uid;
      // Commando updates status/notes; partner cannot update
      allow update: if isAdmin() ||
                    // Partner can only delete their own 'soumis' leads (handled via delete below)
                    (isAuthenticated() && resource.data.partnerId == request.auth.uid &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                     resource.data.status == 'soumis');
      allow delete: if isAdmin() ||
                    (isAuthenticated() && resource.data.partnerId == request.auth.uid &&
                     resource.data.status == 'soumis');
    }

    match /livrables/{livrableId} {
      allow read: if isAdmin() ||
                  (isAuthenticated() && resource.data.developerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.developerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ===============================================================
    // Chat — messagerie documents + messages
    // {clientId} peut representer l'UID d'un client ou d'un membre staff.
    // ===============================================================

    match /chats/{clientId} {
      // Proprietaire du chat + tout le staff
      allow read: if isAuthenticated() && (isOwner(clientId) || isStaff());
      allow create, update: if isAuthenticated() && (isOwner(clientId) || isStaff());
      allow delete: if isStaff();

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (isOwner(clientId) || isStaff());
        allow create: if isAuthenticated() && (isOwner(clientId) || isStaff());
        allow update: if isStaff();
        allow delete: if isStaff();
      }
    }
  }
}
