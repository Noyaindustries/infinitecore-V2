# =============================================================================
# Infinite Core V2 — variables **projet Vercel** (Next + Express serverless)
#
# Scénario par défaut : **tout sur Vercel** — Express est servi sous `/api/*`
# via `pages/api/[[...path]].ts` (serverless-http). Les mêmes clés que
# **.env.example** s’appliquent sur ce projet (Prisma/Mongo, JWT, R2, etc.).
#
# Recopier dans Vercel → Settings → Environment Variables (Production, Preview).
# Ne pas committer de secrets.
# =============================================================================

# --- Obligatoires en production (comme .env.example) -------------------------
DATABASE_URL="mongodb+srv://..."
NEXTAUTH_SECRET="génère-une-chaîne-longue-et-aléatoire"
NEXTAUTH_URL="https://ton-site.vercel.app"
API_PUBLIC_URL="https://ton-site.vercel.app"

# CORS : une origine par entrée (virgule, point-virgule ou espace). Inclure www et preview si besoin.
# Ex. production + preview Vercel :
# CORS_ORIGIN="https://www.infinitecore.net,https://infinitecore-v2.vercel.app"
CORS_ORIGIN="https://ton-site.vercel.app"

# --- Optionnel (aligné sur .env.example) ------------------------------------
# JWT_ISSUER="infinitecore-api"
# JWT_AUDIENCE="infinitecore-web"
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=...
# R2_PUBLIC_BASE_URL=...
# SMTP_HOST=...
# PADDE_WEBHOOK_SECRET=...
# STRIPE_SECRET_KEY=...
# STRIPE_WEBHOOK_SECRET=...
# DATA_QUERY_FETCH_CAP=5000

# =============================================================================
# Front uniquement + API sur un autre domaine (hors modèle par défaut)
# =============================================================================
# Si le navigateur doit appeler une API hébergée ailleurs (CORS requis) :
# NEXT_PUBLIC_API_BASE_URL="https://api.example.com"

# Compat héritée uniquement : JWT Bearer en localStorage côté navigateur
# NEXT_PUBLIC_USE_LEGACY_BEARER="1"

# Google OAuth (sélecteur de compte) — ID client Web, même valeur qu’en local si besoin
# NEXT_PUBLIC_GOOGLE_CLIENT_ID="....apps.googleusercontent.com"
