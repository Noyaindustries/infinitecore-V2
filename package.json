{
  "name": "infinitecore",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"next,api\" -c \"cyan,magenta\" \"next dev --turbo -p 3000\" \"cross-env PORT=3001 tsx server.ts\"",
    "dev:next": "next dev --turbo -p 3000",
    "dev:api": "cross-env PORT=3001 tsx server.ts",
    "build": "next build && npm run build:api",
    "build:api": "esbuild server.ts --bundle --platform=node --target=node18 --packages=external --outfile=dist/server.cjs --format=cjs",
    "build:next": "next build",
    "start": "next start -p 3000",
    "start:api": "node dist/server.cjs",
    "verify:deploy": "node scripts/verifyDeploy.mjs",
    "lint": "tsc --noEmit",
    "test": "npm run test:rbac",
    "test:rbac": "tsx tests/rbac.test.ts",
    "migrate:users": "tsx scripts/migrateUsersToUserAccounts.ts",
    "migrate:users:firebase-live": "tsx scripts/migrateUsersFromFirebaseLive.ts",
    "seed:test-data": "tsx scripts/seedTestData.ts",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "@google/genai": "^0.7.0",
    "@prisma/client": "^6.19.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.2",
    "busboy": "^1.6.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "mongodb": "^7.1.1",
    "multer": "^2.1.1",
    "next": "^15.2.4",
    "nodemailer": "^8.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@netlify/functions": "^5.1.5",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.3",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
