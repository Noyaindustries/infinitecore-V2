# =============================================================================
# Infinite Core V2 — variables d'environnement (référence)
#
# Schéma unique côté code : **src/config/env.ts** (+ **src/config/publicEnv.ts**
# pour NEXT_PUBLIC_* côté navigateur). Les noms ci-dessous = clés process.env.
#
# Copier vers .env et/ou .env.local. Ne pas committer les secrets.
# Vercel (front seul) : **.env.vercel.example**
# =============================================================================

# --- MongoDB (obligatoire sur l’hôte qui exécute l’API / le monolithe) -----
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/infinitecore?retryWrites=true&w=majority"
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=20000

# --- Auth JWT (obligatoire en prod sur l’API ; noms « style NextAuth ») -----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"
# JWT_SECRET=""
# APP_BASE_URL=""
JWT_ISSUER="infinitecore-api"
JWT_AUDIENCE="infinitecore-web"

# --- HTTP / CORS / URL publique API ----------------------------------------
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
API_PUBLIC_URL=""

# --- Stockage fichiers (prod : Cloudflare R2) -------------------------------
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_BASE_URL=""
# R2_ENDPOINT=""

# --- Webhooks & intégrations -------------------------------------------------
PADDE_WEBHOOK_SECRET=""
# INFINITE_CORE_API_URL=""   # Netlify padde-ci (repli : API_PUBLIC_URL)

# --- E-mail (optionnel) ------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM= "Infinite Core <no-reply@infinitecore.ci>"

# --- Vercel (tout-en-un) : mêmes clés que ci-dessus sur le projet Vercel -------
# Voir **.env.vercel.example**. Si le client appelle une API sur un autre domaine :
# NEXT_PUBLIC_API_BASE_URL="https://api.example.com"
# Compat héritée uniquement : JWT Bearer en localStorage côté navigateur
# NEXT_PUBLIC_USE_LEGACY_BEARER="1"

# --- Google Sign-In (OAuth navigateur, sélecteur de compte Google) ------------
# Console Google Cloud → APIs & Services → Identifiants → ID client OAuth « Application Web ».
# Origines JavaScript autorisées : ex. http://localhost:3000 (et l’URL de prod).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID="123456789-xxxx.apps.googleusercontent.com"

# --- Processus & outils -----------------------------------------------------
# PORT=3000
# HOST=0.0.0.0
# SEED_TEST_PASSWORD="Test1234!"
# START_LISTEN=1  # requis pour `npm run start:api` seul (`node dist/server.cjs`)
