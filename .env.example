# MongoDB (Prisma) — chaîne Atlas ou locale
# https://www.prisma.io/docs/orm/overview/databases/mongodb
# En dev, des timeouts courts sont ajoutés automatiquement si vous n’indiquez pas serverSelectionTimeoutMS
# (évite ECONNRESET du proxy Next pendant qu’Atlas ne répond pas). Optionnel :
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/infinitecore?retryWrites=true&w=majority"
JWT_SECRET="change-me-in-production"
JWT_ISSUER="infinitecore-api"
JWT_AUDIENCE="infinitecore-web"
# Origines autorisées pour l’API Express (navigateur). Inclure http://localhost:3000 (Next en local).
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
# Optionnel : URL absolue de l’API si le front ne passe pas par le proxy Next (sinon laisser vide).
NEXT_PUBLIC_API_BASE_URL=""
# Serveur uniquement : URL publique de cette API (ex. Render). Liens /api/files/download sans R2.
API_PUBLIC_URL=""
# Vercel uniquement (variables du dashboard, pas besoin en local si vous utilisez npm run dev) :
# URL publique de l’API Express, sans slash final. Le handler `src/app/api/[[...path]]/route.ts` proxifie `/api/*` vers cette origine.
# API_UPSTREAM="https://infinitecore-api.onrender.com"
PADDE_WEBHOOK_SECRET=""
# URL du front (emails reset mot de passe)
APP_BASE_URL="http://localhost:3000"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Infinite Core <no-reply@infinitecore.ci>"
FIREBASE_ADMIN_EMAIL=""
FIREBASE_ADMIN_PASSWORD=""

# R2, IA, etc. — voir README / code
