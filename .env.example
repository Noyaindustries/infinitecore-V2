# =============================================================================
# Infinite Core V2 — variables d'environnement (référence)
#
# Schéma unique côté code : **src/config/env.ts** (+ **src/config/publicEnv.ts**
# pour NEXT_PUBLIC_* côté navigateur). Les noms ci-dessous = clés process.env.
#
# Copier vers .env et/ou .env.local. Ne pas committer les secrets.
# Vercel (tout-en-un) : **.env.vercel.example**
# Netlify (fonction padde-ci + relais) : **.env.netlify.example**
# =============================================================================

# --- MongoDB (obligatoire sur l’hôte qui exécute l’API / le monolithe) -----
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/infinitecore?retryWrites=true&w=majority"
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=20000

# --- Auth JWT (obligatoire en prod sur l’API ; noms « style NextAuth ») -----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"
# JWT_SECRET=""
# APP_BASE_URL=""
JWT_ISSUER="infinitecore-api"
JWT_AUDIENCE="infinitecore-web"

# --- Données génériques (`POST /api/data/query`) ----------------------------
# Nombre max de documents chargés par collection avant filtrage mémoire (100–20000 ; défaut 5000).
# DATA_QUERY_FETCH_CAP=5000

# --- HTTP / CORS / URL publique API ----------------------------------------
# Prod : https://www.infinitecore.net + https://infinitecore.net + https://padde-ci.com (+ www). Local : ci-dessous.
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,https://www.infinitecore.net,https://infinitecore.net,https://padde-ci.com,https://www.padde-ci.com"
# Base HTTPS de l’API (sans slash final) — liens fichiers, webhooks entrants, etc.
# Prod typique : https://www.infinitecore.net — local : http://localhost:3000
API_PUBLIC_URL="http://localhost:3000"

# --- Stockage fichiers (prod : Cloudflare R2) -------------------------------
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_BASE_URL=""
# R2_ENDPOINT=""

# --- Webhooks & intégrations (PADDE-CI / Noya recrutement → admin / commando) -------------------
# Secret partagé : header X-Webhook-Secret sur POST /api/webhooks/padde-ci
# (et même valeur sur Netlify si vous utilisez la fonction padde-ci).
# Générer : openssl rand -hex 32
# Laisser vide en dev local = webhook sans vérification (pratique mais à éviter en prod).
PADDE_WEBHOOK_SECRET=""
# Secret partagé : header X-Webhook-Secret sur POST /api/webhooks/noya-recrutement
# (formulaire recrutement Noya Industries vers Infinite Core).
# Générer : openssl rand -hex 32
NOYA_RECRUTEMENT_WEBHOOK_SECRET=""
# UID du vrai compte partenaire Noya (collection users / user_accounts.uid)
# Permet d'affecter automatiquement les inscriptions noyaindustries.com/recrutement
# au partenaire Noya dans les espaces Admin/Commando/Partenaire.
NOYA_RECRUTEMENT_PARTNER_ID=""
# Libellé optionnel affiché dans les leads (fallback)
NOYA_RECRUTEMENT_PARTNER_LABEL="Noya Partenaire"
# Test webhook Noya : npm run dev puis npm run test:noya-recrutement-webhook (Node 20+ : node --env-file=.env.local scripts/testNoyaRecrutementWebhook.mjs).
# Test terminal sans padde-ci.com : `npm run dev` puis `npm run test:padde-webhook`
# (Node 20+ : `node --env-file=.env scripts/testPaddeWebhook.mjs`). Option : PADDE_WEBHOOK_TEST_URL=https://…/api/webhooks/padde-ci
# Uniquement sur le site Netlify qui relaie vers l’API (voir .env.netlify.example).
# Sur l’API elle-même : laisser vide et utiliser API_PUBLIC_URL.
# INFINITE_CORE_API_URL=""

# --- Stripe (abonnements) ----------------------------------------------------
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# --- E-mail (optionnel) ------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Infinite Core <no-reply@infinitecore.ci>"
# Alertes équipe (admin + commando) : fusionné avec les e-mails des comptes user_accounts (rôles admin & commando).
# STAFF_NOTIFY_EMAILS="veille@example.com,autre@example.com"

# --- Vercel (tout-en-un) : mêmes clés que ci-dessus sur le projet Vercel -------
# Voir **.env.vercel.example**. Si le client appelle une API sur un autre domaine :
# NEXT_PUBLIC_API_BASE_URL="https://api.example.com"
# Même domaine parent (ex. site sur www, API sur apex ou api.) : partager le cookie de session :
# AUTH_COOKIE_DOMAIN=".example.com"
# Compat héritée uniquement : JWT Bearer en localStorage côté navigateur
# NEXT_PUBLIC_USE_LEGACY_BEARER="1"

# --- Google Sign-In (OAuth navigateur, sélecteur de compte Google) ------------
# Console Google Cloud → APIs & Services → Identifiants → ID client OAuth « Application Web ».
# Origines JavaScript autorisées : ex. http://localhost:3000 (et l’URL de prod).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID="123456789-xxxx.apps.googleusercontent.com"

# --- Processus & outils -----------------------------------------------------
# PORT=3000
# HOST=0.0.0.0
# SEED_TEST_PASSWORD="Test1234!"
# START_LISTEN=1  # requis pour `npm run start:api` seul (`node dist/server.cjs`)
