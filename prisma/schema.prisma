// Schéma MongoDB — Prisma (serveur Node).
// Modèle unifié pour remplacer Firestore/Auth par API + MongoDB.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// Réception webhook PADDE-CI (ex-Firestore `padde_audits` côté serveur).
model PaddeCiAudit {
  id        String   @id @map("_id")
  payload   Json
  createdAt DateTime @default(now())
  processed Boolean  @default(false)

  @@map("padde_ci_audits")
}

/// Document générique compatible "collections/documents" (style Firestore).
model DataDocument {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  collectionPath String
  docId          String
  data           Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([collectionPath, docId])
  @@index([collectionPath])
  @@index([collectionPath, updatedAt(sort: Desc)])
  @@map("data_documents")
}

/// Compte d'authentification natif MongoDB.
model UserAccount {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  uid          String   @unique
  email        String   @unique
  passwordHash String?
  role         String   @default("client")
  firstName    String?
  lastName     String?
  phone        String?
  companyId    String?
  referredBy   String?
  photoURL     String?
  provider     String?
  profile      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
  @@map("user_accounts")
}
