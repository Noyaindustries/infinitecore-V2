{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "moduleDetection": "force",
    "paths": {
      "@/*": ["./src/*"],
      "firebase/app": ["./src/lib/mongoApp.ts"],
      "firebase/auth": ["./src/lib/mongoAuth.ts"],
      "firebase/firestore": ["./src/lib/mongoFirestore.ts"]
    }
  },
  "include": ["next-env.d.ts", "src/env.d.ts", ".next/types/**/*.ts", "src/**/*", "server.ts", "mongoApi.ts", "prismaClient.ts", "_r2.ts", "storageUtils.ts", "scripts/**/*", "tests/**/*", "next.config.ts"],
  "exclude": ["node_modules", "dist", ".next", ".local-uploads", "infinitecore-V2"]
}
