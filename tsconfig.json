{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "firebase/app": [
        "./src/lib/mongoApp.ts"
      ],
      "firebase/auth": [
        "./src/lib/mongoAuth.ts"
      ],
      "firebase/firestore": [
        "./src/lib/mongoFirestore.ts"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "server.ts",
    "mongoApi.ts",
    "prismaClient.ts",
    "_r2.ts",
    "storageUtils.ts",
    "scripts/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules",
    ".local-uploads",
    "infinitecore-V2"
  ]
}