{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "moduleDetection": "force",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    ".next/types/**/*.ts",
    "_r2.ts",
    "mongoApi.ts",
    "next-env.d.ts",
    "next.config.ts",
    "pages/**/*",
    "prismaClient.ts",
    "scripts/**/*",
    "server.ts",
    "src/**/*",
    "src/env.d.ts",
    "storageUtils.ts",
    "tests/**/*",
    ".next-dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".next",
    ".local-uploads",
    "infinitecore-V2"
  ]
}
